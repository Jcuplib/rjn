################################################################################
#
# ------ For Linux64 & intel fortran&C & intel mpi -----
#
################################################################################

##### Fortran setting

FC  = mpiifort

FFLAGS_FAST  = -fpp -m64 -O3 -xMIC-AVX512 -free     \
               -assume byterecl -convert big_endian \
               -fp-model source -align array64byte  \
               -qopt-streaming-stores always        \
               -static_intel

FFLAGS_DEBUG = -fpp -m64 -O0 -xMIC-AVX512 -free          \
               -assume byterecl -convert big_endian      \
               -fpe0 -fp-model source -align array64byte \
               -qopt-streaming-stores always             \
               -static_intel                             \
               -check bounds -warn all -g -traceback     \
               -assume nobuffered_io

# if ILS_DEBUG=T is set, FFLAGS_DEBUG is selected in Mkinclude

##### C setting

CC = mpiicc

CFLAGS_FAST  = -O3 -xMIC-AVX512
CFLAGS_DEBUG = -O0 -xMIC-AVX512

CFLAGS = $(CFLAGS_FAST)

##### Linker setting

LD      = $(FC)
LDFLAGS = $(FFLAGS)

################################################################################

##### for frontend
INSTALL = install
AR      = ar
ARFLAGS = r
RANLIB  = ranlib

RM        = rm
RMFLAGS   = -f
F2PY      = f2py
FCOMPILER = intelem
