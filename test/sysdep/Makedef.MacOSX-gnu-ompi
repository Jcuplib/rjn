################################################################################
#
# ------ For MacOSX & gnu fortran&C & openmpi -----
#
################################################################################

##### Fortran setting

FC  = mpif90

#FFLAGS_FAST  = -cpp -O2 
FFLAGS_FAST  = -cpp -O3 -m64 \
               -std=f2008 -fall-intrinsics -pedantic-errors \
               -fconvert=big-endian -frecord-marker=4 -ffree-form -ffree-line-length-none    \
               -ffpe-summary=none

FFLAGS_DEBUG = -cpp -O0 -m64 \
               -std=f2008 -fall-intrinsics -pedantic-errors \
               -fconvert=big-endian -frecord-marker=4 -ffree-form -ffree-line-length-none    \
               -ffpe-trap=invalid,zero,overflow -finit-integer=-32768 -finit-real=snan -finit-logical=false -finit-character=9 \
               -Wall -Wextra -Wcharacter-truncation -Wunderflow -Warray-temporaries -Wuninitialized -Wconversion-extra \
               -fcheck=bounds,do,mem,pointer \
               -g -fbacktrace

# if ILS_DEBUG=T is set, FFLAGS_DEBUG is selected in Mkinclude

##### C setting

CC  = mpicc

CFLAGS_FAST  = -O3 -m64
CFLAGS_DEBUG = -O0 -m64 -g

CFLAGS = $(CFLAGS_FAST)

##### C++ setting

CXX = mpicxx

CXXFLAGS_FAST  = -O2 -m64 -std=c++11
CXXFLAGS_DEBUG = -O0 -m64 -g -std=c++11

##### NetCDF setting

NETCDFDIR = /opt/homebrew
NETCDFINC = -I$(NETCDFDIR)/include
NETCDFLIB = -L$(NETCDFDIR)/lib -lnetcdff

##### Linker setting

LD      = $(FC)
LDFLAGS = $(FFLAGS)

################################################################################

##### for frontend
INSTALL = install
AR      = ar
ARFLAGS = r
RANLIB  = ranlib

RM        = rm
RMFLAGS   = -f
F2PY      = f2py
FCOMPILER = gnu95
