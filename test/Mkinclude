# System: set SYSTEM to match your environment, or override on command line
# Available: Linux64-gnu-ompi, Linux64-intel-impi, Linux64-intel-ompi,
#            MacOSX-gnu-ompi, yumyum-gnu, yumyum-intel, wink-intel, ...
SYSTEM ?= wink-intel

# TOPDIR must point to the rjn/test/ directory (set by the including Makefile):
#   rjn/test/Makefile      -> TOPDIR = .
#   rjn/test/src/Makefile  -> TOPDIR = ..
#   rjn/test/run/Makefile  -> TOPDIR = ..

# Output directories (relative to TOPDIR = rjn/test/)
BINDIR  = $(TOPDIR)/bin
LIBDIR  = $(TOPDIR)/lib
MODDIR  = $(TOPDIR)/include

# rjn source directory and library
RJNSRCDIR = $(TOPDIR)/../src
RJNLIB    = $(LIBDIR)/librjn.a

# Include system-dependent settings
include $(TOPDIR)/sysdep/Makedef.$(SYSTEM)

ifeq ($(ILS_DEBUG),T)
   CXXFLAGS = $(CXXFLAGS_DEBUG)
   FFLAGS   = $(FFLAGS_DEBUG)
else
   CXXFLAGS = $(CXXFLAGS_FAST)
   FFLAGS   = $(FFLAGS_FAST)
endif

# Fortran module output directory flag:
#   gfortran / mpifort (GNU)  → -J <dir>
#   ifort / ifx / mpiifort    → -module <dir>
FC_BASENAME := $(notdir $(FC))
ifneq (,$(filter ifort ifx mpiifort mpiifx,$(FC_BASENAME)))
  MODFLAG = -module $(MODDIR)
else
  MODFLAG = -J$(MODDIR)
endif
