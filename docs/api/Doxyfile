# Doxygen configuration for Raijin Coupler API documentation.

PROJECT_NAME           = "Raijin Coupler"
PROJECT_NUMBER         = "0.5"
OUTPUT_DIRECTORY       = .
OUTPUT_LANGUAGE        = English

INPUT                  = ../../src
RECURSIVE              = YES
FILE_PATTERNS          = *.h *.hpp *.c *.cc *.cpp *.cxx

EXTRACT_ALL            = YES
